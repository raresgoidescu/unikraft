$(eval $(call addlib_s,libukpod,$(CONFIG_LIBUKPOD)))

CINCLUDES-$(CONFIG_LIBUKPOD) += -I$(LIBUKPOD_BASE)/include
CXXINCLUDES-$(CONFIG_LIBUKPOD) += -I$(LIBUKPOD_BASE)/include

LIBUKPOD_SRCS-$(CONFIG_LIBUKPOD_ANON) += $(LIBUKPOD_BASE)/anon.c
LIBUKPOD_SRCS-$(CONFIG_LIBUKPOD_EAGER) += $(LIBUKPOD_BASE)/eager.c
LIBUKPOD_SRCS-$(CONFIG_LIBUKPOD_DEFAULT_INTERNAL) += $(LIBUKPOD_BASE)/default.c
