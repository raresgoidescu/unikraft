# *** Entry 3: ***
if LIBPOSIX_VFS_FSTAB_FB2

comment "Entry 3:"

config LIBPOSIX_VFS_FSTAB_FB3_DEV
	string "Device"
	help
	  Device to mount the filesystem from. Depending on the selected
	  filesystem, this option may not be required.

config LIBPOSIX_VFS_FSTAB_FB3_MP
	string "Mount point"
	help
	  The path to mount the filesystem on.

config LIBPOSIX_VFS_FSTAB_FB3_DRIVER
	string "Filesystem"
	help
	  The type of filesystem to mount.

config LIBPOSIX_VFS_FSTAB_FB3_FLAGS
	hex "Flags"
	default 0x0
	help
	  Mount flags.

config LIBPOSIX_VFS_FSTAB_FB3_OPTS
	string "Options"
	help
	  Usually a comma-separated list of additional mount options that are
