config LIBPOSIX_VFS_FSTAB_FB1_UKOPTS_IFNOINITRD0_ARG
	bool
	default LIBPOSIX_VFS_FSTAB_FB1_UKOPTS_IFNOINITRD0 if LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM

# *** Entry 2: ***
config LIBPOSIX_VFS_FSTAB_FB2_DEV_ARG
	string
	default LIBPOSIX_VFS_FSTAB_FB2_DEV if LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM

config LIBPOSIX_VFS_FSTAB_FB2_MP_ARG
	string
	default LIBPOSIX_VFS_FSTAB_FB2_MP if LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM

config LIBPOSIX_VFS_FSTAB_FB2_DRIVER_ARG
