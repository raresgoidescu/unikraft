menu "Entry options"

config LIBPOSIX_VFS_FSTAB_FB3_UKOPTS_MKMP
	bool "mkmp - Create mountpoint"

config LIBPOSIX_VFS_FSTAB_FB3_UKOPTS_IFINITRD0
	bool "ifinitrd0 - If 'initrd0' is present"

config LIBPOSIX_VFS_FSTAB_FB3_UKOPTS_IFNOINITRD0
	bool "ifnoinitrd0 - If 'initrd0' is absent"

endmenu

endif # LIBPOSIX_VFS_FSTAB_FB2

endif # LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM

# Invisible options that indicate if an entry was set
config LIBPOSIX_VFS_FSTAB_FB0
	bool
	default y if LIBPOSIX_VFS_FSTAB_FB0_MP_ARG != ""

config LIBPOSIX_VFS_FSTAB_FB1
	bool
	default y if LIBPOSIX_VFS_FSTAB_FB1_MP_ARG != ""

config LIBPOSIX_VFS_FSTAB_FB2
	bool
	default y if LIBPOSIX_VFS_FSTAB_FB2_MP_ARG != ""

config LIBPOSIX_VFS_FSTAB_FB3
	bool
	default y if LIBPOSIX_VFS_FSTAB_FB3_MP_ARG != ""

# NOTE: We use invisible *_ARG values similar to builtin fstab

# *** Entry 0: ***
config LIBPOSIX_VFS_FSTAB_FB0_DEV_ARG
	string
	default LIBPOSIX_VFS_FSTAB_FB0_DEV if LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM
	default "initrd0" if LIBPOSIX_VFS_FSTAB_FALLBACK_INITRD_EXTRACT
	default "embedded" if LIBPOSIX_VFS_FSTAB_FALLBACK_EINITRD_EXTRACT

config LIBPOSIX_VFS_FSTAB_FB0_MP_ARG
	string
	default LIBPOSIX_VFS_FSTAB_FB0_MP if LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM
	default LIBPOSIX_VFS_FSTAB_FB_MP if LIBPOSIX_VFS_FSTAB_BUILTIN && !LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM
	default "/" if !LIBPOSIX_VFS_FSTAB_BUILTIN && LIBPOSIX_VFS_FSTAB_FALLBACK_RAMFS
	default "/" if !LIBPOSIX_VFS_FSTAB_BUILTIN && LIBPOSIX_VFS_FSTAB_FALLBACK_INITRD
	default "/" if !LIBPOSIX_VFS_FSTAB_BUILTIN && LIBPOSIX_VFS_FSTAB_FALLBACK_EINITRD

config LIBPOSIX_VFS_FSTAB_FB0_DRIVER_ARG
	string
	default LIBPOSIX_VFS_FSTAB_FB0_DRIVER if LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM
	default "ramfs" if LIBPOSIX_VFS_FSTAB_FALLBACK_RAMFS
	default "ramfs" if LIBPOSIX_VFS_FSTAB_FALLBACK_INITRD
	default "ramfs" if LIBPOSIX_VFS_FSTAB_FALLBACK_EINITRD
	default "extract" if LIBPOSIX_VFS_FSTAB_FALLBACK_INITRD_EXTRACT
	default "extract" if LIBPOSIX_VFS_FSTAB_FALLBACK_EINITRD_EXTRACT

config LIBPOSIX_VFS_FSTAB_FB0_FLAGS_ARG
	hex
	default 0x0
	default LIBPOSIX_VFS_FSTAB_FB0_FLAGS if LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM

config LIBPOSIX_VFS_FSTAB_FB0_OPTS_ARG
	string
	default LIBPOSIX_VFS_FSTAB_FB0_OPTS if LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM

config LIBPOSIX_VFS_FSTAB_FB0_UKOPTS_MKMP_ARG
	bool
	default LIBPOSIX_VFS_FSTAB_FB0_UKOPTS_MKMP if LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM
	default LIBPOSIX_VFS_FSTAB_FB_UKOPTS_MKMP if LIBPOSIX_VFS_FSTAB_BUILTIN && !LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM

config LIBPOSIX_VFS_FSTAB_FB0_UKOPTS_IFINITRD0_ARG
	bool
	default LIBPOSIX_VFS_FSTAB_FB0_UKOPTS_IFINITRD0 if LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM
	default LIBPOSIX_VFS_FSTAB_FB_UKOPTS_IFINITRD0 if LIBPOSIX_VFS_FSTAB_BUILTIN && !LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM

config LIBPOSIX_VFS_FSTAB_FB0_UKOPTS_IFNOINITRD0_ARG
	bool
	default LIBPOSIX_VFS_FSTAB_FB0_UKOPTS_IFNOINITRD0 if LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM
	default LIBPOSIX_VFS_FSTAB_FB_UKOPTS_IFNOINITRD0 if LIBPOSIX_VFS_FSTAB_BUILTIN && !LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM

# *** Entry 1: ***
config LIBPOSIX_VFS_FSTAB_FB1_DEV_ARG
	string
	default LIBPOSIX_VFS_FSTAB_FB1_DEV if LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM
	default "initrd0" if LIBPOSIX_VFS_FSTAB_FALLBACK_INITRD
	default "embedded" if LIBPOSIX_VFS_FSTAB_FALLBACK_EINITRD

config LIBPOSIX_VFS_FSTAB_FB1_MP_ARG
	string
	default LIBPOSIX_VFS_FSTAB_FB1_MP if LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM
	default LIBPOSIX_VFS_FSTAB_FB_MP if LIBPOSIX_VFS_FSTAB_FALLBACK_INITRD
	default LIBPOSIX_VFS_FSTAB_FB_MP if LIBPOSIX_VFS_FSTAB_FALLBACK_EINITRD

config LIBPOSIX_VFS_FSTAB_FB1_DRIVER_ARG
	string
	default LIBPOSIX_VFS_FSTAB_FB1_DRIVER if LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM
	default "extract" if LIBPOSIX_VFS_FSTAB_FALLBACK_INITRD
	default "extract" if LIBPOSIX_VFS_FSTAB_FALLBACK_EINITRD

config LIBPOSIX_VFS_FSTAB_FB1_FLAGS_ARG
