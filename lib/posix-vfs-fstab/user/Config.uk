	default 0x0
	default LIBPOSIX_VFS_FSTAB_FB1_FLAGS if LIBPOSIX_VFS_FSTAB_FALLBACK_CUSTOM

config LIBPOSIX_VFS_FSTAB_FB1_OPTS_ARG
