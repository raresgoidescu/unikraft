### Built-in fstab detailed config

if LIBPOSIX_VFS_FSTAB

if LIBPOSIX_VFS_FSTAB_BUILTIN

choice LIBPOSIX_VFS_FSTAB_BUILTIN_CONF
	prompt "Configuration"
	default LIBPOSIX_VFS_FSTAB_BUILTIN_CUSTOM

config LIBPOSIX_VFS_FSTAB_BUILTIN_RAMFS
	bool "RAMfs"
	select LIBUKFS_RAMFS
	help
	  Mount empty RAMfs at /.

config LIBPOSIX_VFS_FSTAB_BUILTIN_INITRD
	bool "RAMfs + CPIO initrd"
	select LIBUKFS_RAMFS
	select LIBUKCPIO
	help
	  Extract a user-supplied initrd into an empty RAMfs mounted at /.

config LIBPOSIX_VFS_FSTAB_BUILTIN_EINITRD
	bool "RAMfs + compiled-in CPIO initrd"
	select LIBPOSIX_VFS_FSTAB_EINITRD
	select LIBUKFS_RAMFS
	select LIBUKCPIO
	help
	  Extract a compiled-in initrd into an empty RAMFS mounted at /.

config LIBPOSIX_VFS_FSTAB_BUILTIN_CUSTOM
	bool "Custom"
	help
	  Custom fstab entries to be mounted early in boot.

endchoice

if LIBPOSIX_VFS_FSTAB_BUILTIN_CUSTOM

# *** Entry 0: ***
comment "Entry 0:"

config LIBPOSIX_VFS_FSTAB_BI0_DEV
	string "Device"
	help
	  Device to mount the filesystem from. Depending on the selected
	  filesystem, this option may not be required.

config LIBPOSIX_VFS_FSTAB_BI0_MP
	string "Mount point"
	help
	  The path to mount the filesystem on.

config LIBPOSIX_VFS_FSTAB_BI0_DRIVER
	string "Filesystem"
	help
	  The type of filesystem to mount.

config LIBPOSIX_VFS_FSTAB_BI0_FLAGS
	hex "Flags"
	default 0x0
	help
	  Mount flags.

config LIBPOSIX_VFS_FSTAB_BI0_OPTS
	string "Options"
	help
	  Usually a comma-separated list of additional mount options that are
	  directly interpreted by the target filesystem.

menu "Entry options"

config LIBPOSIX_VFS_FSTAB_BI0_UKOPTS_MKMP
	bool "mkmp - Create mountpoint"

config LIBPOSIX_VFS_FSTAB_BI0_UKOPTS_IFINITRD0
	bool "ifinitrd0 - If 'initrd0' is present"

config LIBPOSIX_VFS_FSTAB_BI0_UKOPTS_IFNOINITRD0
	bool "ifnoinitrd0 - If 'initrd0' is absent"

endmenu

# *** Entry 1: ***
if LIBPOSIX_VFS_FSTAB_BI0

comment "Entry 1:"

config LIBPOSIX_VFS_FSTAB_BI1_DEV
	string "Device"
	help
	  Device to mount the filesystem from. Depending on the selected
	  filesystem, this option may not be required.

config LIBPOSIX_VFS_FSTAB_BI1_MP
	string "Mount point"
