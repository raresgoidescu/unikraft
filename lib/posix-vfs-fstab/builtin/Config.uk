# Invisible options that indicate if an entry was set
config LIBPOSIX_VFS_FSTAB_BI0
	bool
	default y if LIBPOSIX_VFS_FSTAB_BI0_MP_ARG != ""

config LIBPOSIX_VFS_FSTAB_BI1
	bool
	default y if LIBPOSIX_VFS_FSTAB_BI1_MP_ARG != ""

config LIBPOSIX_VFS_FSTAB_BI2
	bool
	default y if LIBPOSIX_VFS_FSTAB_BI2_MP_ARG != ""

config LIBPOSIX_VFS_FSTAB_BI3
	bool
	default y if LIBPOSIX_VFS_FSTAB_BI3_MP_ARG != ""

# NOTE:
# In the following, we take over setting into invisible *_ARG depending on
# configuration. This is done to avoid conflicts of values set differently
# between configuration changes.
# We are making use here of invisible configurations that are not loaded from
# `.config`. We can use them to pick the actual values we want to have.

# *** Entry 0: ***
config LIBPOSIX_VFS_FSTAB_BI0_DEV_ARG
	string
	default LIBPOSIX_VFS_FSTAB_BI0_DEV if LIBPOSIX_VFS_FSTAB_BUILTIN_CUSTOM

config LIBPOSIX_VFS_FSTAB_BI0_MP_ARG
	string
	default LIBPOSIX_VFS_FSTAB_BI0_MP if LIBPOSIX_VFS_FSTAB_BUILTIN_CUSTOM
	default "/" if LIBPOSIX_VFS_FSTAB_BUILTIN_RAMFS
	default "/" if LIBPOSIX_VFS_FSTAB_BUILTIN_INITRD
	default "/" if LIBPOSIX_VFS_FSTAB_BUILTIN_EINITRD

config LIBPOSIX_VFS_FSTAB_BI0_DRIVER_ARG
	string
	default LIBPOSIX_VFS_FSTAB_BI0_DRIVER if LIBPOSIX_VFS_FSTAB_BUILTIN_CUSTOM
	default "ramfs" if LIBPOSIX_VFS_FSTAB_BUILTIN_RAMFS
	default "ramfs" if LIBPOSIX_VFS_FSTAB_BUILTIN_INITRD
	default "ramfs" if LIBPOSIX_VFS_FSTAB_BUILTIN_EINITRD

config LIBPOSIX_VFS_FSTAB_BI0_FLAGS_ARG
	hex
	default 0x0
	default LIBPOSIX_VFS_FSTAB_BI0_FLAGS if LIBPOSIX_VFS_FSTAB_BUILTIN_CUSTOM

config LIBPOSIX_VFS_FSTAB_BI0_OPTS_ARG
	string
	default LIBPOSIX_VFS_FSTAB_BI0_OPTS if LIBPOSIX_VFS_FSTAB_BUILTIN_CUSTOM

config LIBPOSIX_VFS_FSTAB_BI0_UKOPTS_MKMP_ARG
	bool
	default LIBPOSIX_VFS_FSTAB_BI0_UKOPTS_MKMP if LIBPOSIX_VFS_FSTAB_BUILTIN_CUSTOM

config LIBPOSIX_VFS_FSTAB_BI0_UKOPTS_IFINITRD0_ARG
	bool
	default LIBPOSIX_VFS_FSTAB_BI0_UKOPTS_IFINITRD0 if LIBPOSIX_VFS_FSTAB_BUILTIN_CUSTOM

config LIBPOSIX_VFS_FSTAB_BI0_UKOPTS_IFNOINITRD0_ARG
	bool
	default LIBPOSIX_VFS_FSTAB_BI0_UKOPTS_IFNOINITRD0 if LIBPOSIX_VFS_FSTAB_BUILTIN_CUSTOM

# *** Entry 1: ***
config LIBPOSIX_VFS_FSTAB_BI1_DEV_ARG
	string
	default LIBPOSIX_VFS_FSTAB_BI1_DEV if LIBPOSIX_VFS_FSTAB_BUILTIN_CUSTOM
	default "initrd0" if LIBPOSIX_VFS_FSTAB_BUILTIN_INITRD
	default "embedded" if LIBPOSIX_VFS_FSTAB_BUILTIN_EINITRD

config LIBPOSIX_VFS_FSTAB_BI1_MP_ARG
	string
	default LIBPOSIX_VFS_FSTAB_BI1_MP if LIBPOSIX_VFS_FSTAB_BUILTIN_CUSTOM
	default "/" if LIBPOSIX_VFS_FSTAB_BUILTIN_INITRD
	default "/" if LIBPOSIX_VFS_FSTAB_BUILTIN_EINITRD

config LIBPOSIX_VFS_FSTAB_BI1_DRIVER_ARG
	string
	default LIBPOSIX_VFS_FSTAB_BI1_DRIVER if LIBPOSIX_VFS_FSTAB_BUILTIN_CUSTOM
	default "extract" if LIBPOSIX_VFS_FSTAB_BUILTIN_INITRD
	default "extract" if LIBPOSIX_VFS_FSTAB_BUILTIN_EINITRD

config LIBPOSIX_VFS_FSTAB_BI1_FLAGS_ARG
	hex
	default 0x0
	default LIBPOSIX_VFS_FSTAB_BI1_FLAGS if LIBPOSIX_VFS_FSTAB_BUILTIN_CUSTOM

config LIBPOSIX_VFS_FSTAB_BI1_OPTS_ARG
